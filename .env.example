PORT=3000

# Twilio -- leave blank to run in demo mode (mock driver, no network calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+15551234567

# Where to ping for high-intent leads (Slack incoming webhook, CRM endpoint, etc.)
LEAD_NOTIFY_WEBHOOK=

# Optional LLM fallback -- leave empty for rule-only classification
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest

# Owner timezone + quiet hours (24h clock)
OWNER_TIMEZONE=America/New_York
QUIET_HOURS_START=21
QUIET_HOURS_END=9

# SQLite path
DATABASE_PATH=./data/leads.sqlite
